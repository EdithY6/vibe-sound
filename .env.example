# Copy to .env on the server (never commit .env)
# https://huggingface.co/settings/tokens
# Accept: https://huggingface.co/MelodyWEN7/vibesound-music-mood-classifier

HF_TOKEN=hf_your_token_here

# Music generation: local GPU MusicGen on UST server
VIBESOUND_MUSIC_BACKEND=local

# Download format: mp4 (needs ffmpeg) or wav
VIBESOUND_AUDIO_FORMAT=mp4

# deploy.sh sets this when ffmpeg is found; override if needed
# FFMPEG_PATH=/usr/bin/ffmpeg

# Optional model overrides (defaults are fine)
# MUSICGEN_MODEL=facebook/musicgen-small
# VIBESOUND_CLAP_MODEL=laion/clap-htsat-fused

# Only for app_flan.py ablation
# VIBESOUND_FLAN_MODEL=google/flan-t5-small
# VIBESOUND_FLAN_MAX_NEW_TOKENS=72

# Only for app_musiccaps.py ablation
# VIBESOUND_MUSICCAPS_DATASET=google/MusicCaps
# VIBESOUND_MUSICCAPS_MAX_ROWS=5521
# VIBESOUND_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
